# ───────────────────────────────────────────────────────────────────────────
# Rexer Micro-Tools — environment variables
#
# Non-AI tools are 100% client-side and need NO server keys.
# The variables below are for the AI category (Step 9) only.
# Copy this file to `.env.local` and fill in keys locally.
# NEVER commit real secrets. Access via process.env only.
# ───────────────────────────────────────────────────────────────────────────

# --- AI providers (used by /api/ai/* routes, Step 9+) -----------------------
# Anthropic Claude (primary text/code)
ANTHROPIC_API_KEY=

# OpenAI (fallback text/code + Whisper STT/TTS)
OPENAI_API_KEY=

# Replicate / Stable Diffusion (image gen / enhance)
REPLICATE_API_TOKEN=

# --- AI abuse controls -----------------------------------------------------
# Sliding-window rate limit per IP/session (requests per minute)
REXER_RATE_LIMIT=60

# Hard token budget per session (AI endpoints)
REXER_MAX_TOKENS_PER_SESSION=50000

# Max request body size for AI endpoints in bytes (default ~1MB)
REXER_MAX_REQUEST_BYTES=1048576

# --- Analytics (privacy-friendly, opt-in) ----------------------------------
# Plausible self-host or cloud. Leave empty to disable.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Rexer Micro-Tools"
NEXT_PUBLIC_APP_URL=http://localhost:3000
